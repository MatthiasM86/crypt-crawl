; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Crypt Crawl"
config/icon="res://assets/icon.png"
run/main_scene="res://scenes/hub/hub.tscn"
config/features=PackedStringArray("4.3")

[autoload]

GameManager="*res://autoloads/game_manager.gd"
Sfx="*res://autoloads/sfx.gd"
PauseMenu="*res://autoloads/pause_menu.gd"
DeathScreen="*res://autoloads/death_screen.gd"
WinScreen="*res://autoloads/win_screen.gd"
LoadoutChoice="*res://autoloads/loadout_choice.gd"
FullMap="*res://autoloads/full_map.gd"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[gui]

theme/custom="res://assets/ui/hud_theme.tres"

